# Copy to .env.local and fill in from your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Optional: shared invite code required to create an account on the login page.
# Leave unset for open sign-up; set it to gate self-registration to your teachers.
NEXT_PUBLIC_SIGNUP_CODE=
